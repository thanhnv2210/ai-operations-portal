# AI Operations Portal — environment variable reference
# Copy to .env.local (gitignored) and fill in your values.

# ── Required ──────────────────────────────────────────────
APP_ENV=local                        # local | ci | uat

# Non-secure DB — product config, reference data (ml_schema, service_management)
ML_DB_URL=postgresql+asyncpg://admin:admin@localhost:54320/ml_db

# Secure DB — transactions, customers, payments (remittance, customer, payment, portal, ekyc)
KEYCLOAK_DB_URL=postgresql+asyncpg://admin:admin@localhost:54320/keycloak

ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides (defaults shown) ───────────────────
# ANTHROPIC_MODEL=claude-opus-4-6
# ANTHROPIC_CONCURRENCY=5
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral
# CORS_ORIGINS=["http://localhost:3001"]
