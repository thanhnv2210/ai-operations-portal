# Copy to .env.local and fill in your values.
# This file is committed; .env.local is gitignored.

APP_ENV=local

# Non-secure DB (product config, reference data)
ML_DB_URL=postgresql+asyncpg://admin:admin@localhost:54320/ml_db

# Secure DB (transactions, customers, payments)
KEYCLOAK_DB_URL=postgresql+asyncpg://admin:admin@localhost:54320/keycloak

# AI
ANTHROPIC_API_KEY=sk-ant-...
# Optional — enables OpenAI text-embedding-3-small for RAG embeddings.
# Falls back to Ollama nomic-embed-text (requires: ollama pull nomic-embed-text) when unset.
# OPENAI_API_KEY=sk-...

# Optional overrides (defaults shown)
# ANTHROPIC_MODEL=claude-opus-4-6
# ANTHROPIC_CONCURRENCY=5
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral
# CORS_ORIGINS=["http://localhost:3001"]

# Langfuse LLM observability (optional — tracing is disabled when these are unset)
# Self-hosted: docker run -p 3000:3000 langfuse/langfuse (then set HOST below)
# Cloud:       sign up at langfuse.com, copy keys from project settings
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3020   # omit for cloud (defaults to https://cloud.langfuse.com)
