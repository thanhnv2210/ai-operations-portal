# Copy to .env.local and fill in your values.
# This file is committed; .env.local is gitignored.

APP_ENV=local

# Non-secure DB (product config, reference data)
ML_DB_URL=postgresql+asyncpg://admin:admin@localhost:54320/ml_db

# Secure DB (transactions, customers, payments)
KEYCLOAK_DB_URL=postgresql+asyncpg://admin:admin@localhost:54320/keycloak

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown)
# ANTHROPIC_MODEL=claude-opus-4-6
# ANTHROPIC_CONCURRENCY=5
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral
# CORS_ORIGINS=["http://localhost:3001"]
